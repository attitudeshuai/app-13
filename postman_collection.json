              "raw": "{{baseUrl}}/api/consumptionrecords",
              "host": ["{{baseUrl}}"],
              "path": ["api", "consumptionrecords"]
            }
          }
        }
      ]
    },
    {
      "name": "统计分析",
      "item": [
        {
          "name": "获取总览统计",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/stats/overview?householdId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stats", "overview"],
              "query": [
                {
                  "key": "householdId",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "获取趋势统计",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/stats/trend?startDate=2024-01-01&endDate=2024-01-31&householdId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stats", "trend"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2024-01-01"
                },
                {
                  "key": "endDate",
                  "value": "2024-01-31"
                },
                {
                  "key": "householdId",
                  "value": "1"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
