          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/expiryalerts/read-all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "expiryalerts", "read-all"]
