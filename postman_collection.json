          }
        }
      ]
    },
    {
      "name": "消耗记录",
      "item": [
        {
          "name": "获取我的消耗记录",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/consumptionrecords/mine",
              "host": ["{{baseUrl}}"],
              "path": ["api", "consumptionrecords", "mine"]
            }
          }
        },
        {
          "name": "记录消耗",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('记录成功', function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.code).to.eql(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
